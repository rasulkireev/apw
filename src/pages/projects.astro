---
import BaseLayout from '../layouts/BaseLayout.astro';
import projectsData from '../assets/data/projects.json';

const pageTitle = "Rasul Kireev's Launched Project Archive";
const pageDescription = "A focused archive of launched side projects and commercial experiments Rasul Kireev has worked on since 2018.";
const pageKeywords = "Rasul Kireev projects, launched side projects, commercial side projects, SaaS, Django projects, indie hacking, developer tools";

const snapshotDate = new Date(projectsData.generatedAt);
const MS_PER_DAY = 1000 * 60 * 60 * 24;

const displayNameOverrides = new Map([
  ['django-saas-starter', 'Djass'],
  ['filebridge', 'FileBridge'],
  ['isitketo-django', 'Is It Keto'],
  ['osig', 'OSIG'],
  ['statushen', 'StatusHen'],
  ['talentleads', 'Talent Leads'],
  ['tjalerts', 'TJ Alerts'],
  ['tolstoy_calendar', 'Tolstoy Newsletter'],
]);

const descriptionOverrides = new Map([
  ['django-saas-starter', 'A Django SaaS starter template for launching paid web apps faster.'],
  ['cleanapp', 'An Anki-style habit for keeping old pages, styles, and content fresh.'],
  ['filebridge', 'A product for turning uploaded files into clean API endpoints and structured data feeds.'],
  ['isitketo-django', 'A food lookup site for learning what is keto compliant.'],
  ['levreview', 'A tool for helping local businesses improve their Google review flow.'],
  ['statushen', 'Uptime monitoring and status pages for SaaS projects.'],
  ['talentleads', 'A recruiting lead tool for startups looking for strong technical talent.'],
  ['tjalerts', 'A job alert product for staying on top of new roles in the tech market.'],
]);

const homepageOverrides = new Map([
  ['cleanapp', 'https://cleanapp.dev'],
  ['django-saas-starter', 'https://djass.dev'],
  ['isitketo-django', 'https://isitketo.org'],
  ['levreview', 'https://levreview.com'],
  ['talentleads', 'https://gettalentleads.com'],
  ['tjalerts', 'https://gettjalerts.com'],
  ['ask-hn-digests', 'https://askhndigests.com/'],
]);

function readableName(name: string) {
  if (displayNameOverrides.has(name)) return displayNameOverrides.get(name);

  return name
    .replace(/\.(ru|com|dev|app)$/i, '.$1')
    .replace(/[-_]/g, ' ')
    .replace(/\b\w/g, (letter) => letter.toUpperCase());
}

function dateValue(value?: string | null) {
  return value ? new Date(value).getTime() : 0;
}

function yearFrom(value?: string | null) {
  if (!value) return null;
  return new Date(value).getUTCFullYear();
}

function daysSince(value?: string | null) {
  if (!value) return null;
  return Math.max(0, Math.floor((snapshotDate.getTime() - new Date(value).getTime()) / MS_PER_DAY));
}

const whatHappenedOptions = {
  active: {
    label: 'Active',
    tone: 'active',
    dotClass: 'bg-emerald-500',
    textClass: 'text-emerald-700',
  },
  idle: {
    label: 'Idle',
    tone: 'idle',
    title: 'It is live, but not in active development.',
    dotClass: 'bg-amber-400',
    textClass: 'text-amber-700',
  },
  closed: {
    label: 'Shut it down',
    tone: 'closed',
    dotClass: 'bg-stone-300',
    textClass: 'text-stone-500',
  },
};

function whatHappenedFor(project: (typeof projectsData.projects)[number], lastAt?: string | null) {
  if (project.statusOverride && project.statusOverride in whatHappenedOptions) {
    return whatHappenedOptions[project.statusOverride as keyof typeof whatHappenedOptions];
  }

  if (project.closedYear) {
    return whatHappenedOptions.closed;
  }

  if (!lastAt) {
    return whatHappenedOptions.closed;
  }

  const days = daysSince(lastAt) ?? Infinity;
  if (!project.isArchived && days <= 90) {
    return whatHappenedOptions.active;
  }

  if (!project.isArchived && days <= 365) {
    return whatHappenedOptions.idle;
  }

  return whatHappenedOptions.closed;
}

function primaryUrlFor(project: (typeof projectsData.projects)[number]) {
  if (Array.isArray(project.links)) return project.links[0]?.url ?? null;
  if (project.closedYear && project.url) return project.url;
  return homepageOverrides.get(project.name) ?? project.homepageUrl ?? project.url ?? null;
}

const projects = projectsData.projects
  .map((project) => {
    const startAt = project.startedAt ?? project.firstCommitAt ?? project.createdAt;
    const lastAt = project.lastCommitAt ?? project.pushedAt ?? project.updatedAt;
    const whatHappened = whatHappenedFor(project, lastAt);
    const startYear = yearFrom(startAt);

    return {
      ...project,
      displayName: project.displayName ?? readableName(project.name),
      description: descriptionOverrides.get(project.name) ?? project.description,
      primaryUrl: primaryUrlFor(project),
      whatHappened,
      startYear,
    };
  })
  .sort((a, b) => {
    const yearDelta = (a.startYear ?? 0) - (b.startYear ?? 0);
    if (yearDelta !== 0) return yearDelta;
    return dateValue(a.firstCommitAt ?? a.createdAt ?? a.startedAt) - dateValue(b.firstCommitAt ?? b.createdAt ?? b.startedAt);
  });
---

<BaseLayout
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  pageKeywords={pageKeywords}
>
  <p class="mb-4 text-sm text-stone-700">
    Since 2018, I've launched {projects.length} projects while trying to turn side ideas into real products and businesses, with no success yet.
  </p>

  <div class="overflow-x-auto">
    <table class="w-full min-w-[680px] border-collapse text-sm text-stone-900">
      <thead class="border-b border-stone-300 text-left font-bold text-stone-600">
        <tr>
          <th scope="col" class="py-2 pr-4">Project</th>
          <th scope="col" class="w-20 px-4 py-2">Started</th>
          <th scope="col" class="px-4 py-2">Description</th>
          <th scope="col" class="w-32 py-2 pl-4">What Happened</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-stone-200">
        {projects.map((project) => (
          <tr>
            <td class="min-w-40 py-2 pr-4 align-top font-bold">
              {project.primaryUrl ? (
                <a class="underline decoration-stone-300 underline-offset-2 hover:text-black hover:decoration-current" href={project.primaryUrl} target="_blank" rel="noreferrer">
                  {project.displayName}
                </a>
              ) : (
                project.displayName
              )}
            </td>
            <td class="px-4 py-2 align-top tabular-nums text-stone-600">
              {project.startYear ?? 'Unknown'}
            </td>
            <td class="min-w-[20rem] max-w-xl px-4 py-2 align-top text-stone-700">
              {project.description}
            </td>
            <td class="py-2 pl-4 align-top">
              <span class:list={[
                'group inline-flex flex-col items-start gap-1 whitespace-nowrap',
                project.whatHappened.tone === 'idle' && 'cursor-help focus:outline-none',
              ]} tabindex={project.whatHappened.tone === 'idle' ? 0 : undefined}>
                <span class:list={[
                  'inline-flex items-center gap-2',
                  project.whatHappened.textClass,
                  project.whatHappened.tone === 'idle' && 'underline decoration-dotted underline-offset-4',
                ]}>
                  <span class:list={[
                    'h-2 w-2 rounded-full',
                    project.whatHappened.dotClass,
                  ]} aria-hidden="true" />
                  {project.whatHappened.label}
                </span>
                {project.whatHappened.tone === 'idle' && project.whatHappened.title && (
                  <span class="hidden max-w-44 whitespace-normal rounded border border-amber-200 bg-amber-50 px-2 py-1 text-xs font-normal leading-snug text-amber-900 shadow-sm group-hover:block group-focus:block">
                    {project.whatHappened.title}
                  </span>
                )}
              </span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</BaseLayout>
