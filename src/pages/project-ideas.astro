    <p>
      If you are a developer, you probably know this problem well: you have a million ideas for projects,
      but you do not have time to build all of them.
    </p>
    <p>
      These used to be scattered across Google Keep, Google Sheets, Obsidian, Todoist, and text files.
      Now they are tracked here and shared publicly.
    </p>
    <p>
      Everything is now in one list. Scores are subjective and intentionally rough so I can prioritize what to ship next.
    </p>
    <p>
      <strong>Difficulty:</strong> 0 = super easy, 10 = nearly impossible.
      <br />
      <strong>$$$ potential:</strong> 0 = basically no revenue path, 10 = unicorn-scale upside.
    </p>
    <p>
      If you have comments, questions, or want to build one together,
      <a href="mailto:kireevr1996@gmail.com">let me know</a>.
    </p>

    <hr />

    <h2>All project ideas</h2>
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end">
      <label class="flex w-full flex-col gap-1 text-base">
        <span class="font-semibold">Search</span>
        <input
          id="ideaSearch"
          type="search"
          placeholder="Search ideas..."
          class="w-full rounded-md border border-slate-300 px-3 py-2 text-base shadow-sm focus:border-slate-500 focus:outline-none"
        />
      </label>
    </div>
    <div class="w-full overflow-x-auto rounded-lg border border-slate-200 bg-white shadow-sm">
      <table class="min-w-full border-collapse text-left text-base">
        <thead class="bg-slate-100 text-sm uppercase tracking-wide text-slate-600">
          <tr>
            <th class="px-4 py-3 font-semibold">
              <button type="button" class="flex w-full items-center justify-between gap-2" data-sort="index">
                <span>#</span>
                <span class="text-xs text-slate-500" data-sort-indicator></span>
              </button>
            </th>
            <th class="px-4 py-3 font-semibold">
              <button type="button" class="flex w-full items-center justify-between gap-2" data-sort="idea">
                <span>Idea</span>
                <span class="text-xs text-slate-500" data-sort-indicator></span>
              </button>
            </th>
            <th class="px-4 py-3 font-semibold">
              <button type="button" class="flex w-full items-center justify-between gap-2" data-sort="description">
                <span>Description</span>
                <span class="text-xs text-slate-500" data-sort-indicator></span>
              </button>
            </th>
            <th class="px-4 py-3 font-semibold">
              <button type="button" class="flex w-full items-center justify-between gap-2" data-sort="difficulty">
                <span>Difficulty</span>
                <span class="text-xs text-slate-500" data-sort-indicator></span>
              </button>
            </th>
            <th class="px-4 py-3 font-semibold">
              <button type="button" class="flex w-full items-center justify-between gap-2" data-sort="money">
                <span>Money potential</span>
                <span class="text-xs text-slate-500" data-sort-indicator></span>
              </button>
            </th>
          </tr>
        </thead>
        <tbody id="ideasTableBody" class="divide-y divide-slate-200">
          {projectIdeas.map((idea, index) => (
            <tr
              class="align-top"
              data-search={`${idea.title} ${idea.description}`.toLowerCase()}
              data-idea={idea.title}
              data-description={idea.description}
              data-difficulty={idea.difficulty}
              data-money={idea.moneyPotential}
              data-index={index}
            >
              <td class="whitespace-nowrap px-4 py-3 font-mono text-sm text-slate-500">{index + 1}</td>
              <td class="px-4 py-3 font-semibold text-slate-900">{idea.title}</td>
              <td class="min-w-[18rem] px-4 py-3 text-slate-700">{idea.description}</td>
              <td class="whitespace-nowrap px-4 py-3 text-slate-700">{idea.difficulty}/10</td>
              <td class="whitespace-nowrap px-4 py-3 text-slate-700">{idea.moneyPotential}/10</td>
            </tr>
          ))}
          <tr id="ideasNoResults" class="hidden">
            <td class="px-4 py-6 text-center text-slate-500" colspan="5">
              No ideas match your search.
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>

<script>
  const searchInput = document.getElementById('ideaSearch');
  const ideasTableBody = document.getElementById('ideasTableBody');
  const noResultsRow = document.getElementById('ideasNoResults');
  const sortButtons = Array.from(document.querySelectorAll('[data-sort]'));

  if (searchInput && ideasTableBody) {
    const rows = Array.from(ideasTableBody.querySelectorAll('tr[data-index]'));
    const sortState = {
      key: 'index',
      direction: 'asc',
    };

    const getSortValue = (row, key) => {
      if (key === 'difficulty') {
        return Number(row.dataset.difficulty || 0);
      }
      if (key === 'money') {
        return Number(row.dataset.money || 0);
      }
      if (key === 'idea') {
        return (row.dataset.idea || '').toLowerCase();
      }
      if (key === 'description') {
        return (row.dataset.description || '').toLowerCase();
      }
      return Number(row.dataset.index || 0);
    };

    const updateSortIndicators = () => {
      sortButtons.forEach((button) => {
        const indicator = button.querySelector('[data-sort-indicator]');
        if (!indicator) {
          return;
        }
        if (button.dataset.sort === sortState.key) {
          indicator.textContent = sortState.direction === 'asc' ? '▲' : '▼';
        } else {
          indicator.textContent = '';
        }
      });
    };

    const applyFilters = () => {
      const query = searchInput.value.trim().toLowerCase();

      const visibleRows = rows.filter((row) => {
        if (!query) {
          return true;
        }
        const haystack = row.dataset.search || '';
        return haystack.includes(query);
      });

      const sortedRows = [...visibleRows].sort((a, b) => {
        const aKey = getSortValue(a, sortState.key);
        const bKey = getSortValue(b, sortState.key);

        if (aKey === bKey) {
          return Number(a.dataset.index || 0) - Number(b.dataset.index || 0);
        }

        if (sortState.key === 'idea' || sortState.key === 'description') {
          return sortState.direction === 'asc' ? aKey.localeCompare(bKey) : bKey.localeCompare(aKey);
        }

        return sortState.direction === 'asc' ? aKey - bKey : bKey - aKey;
      });

      rows.forEach((row) => {
        row.style.display = visibleRows.includes(row) ? '' : 'none';
      });

      sortedRows.forEach((row) => {
        ideasTableBody.appendChild(row);
      });

      if (noResultsRow) {
        noResultsRow.classList.toggle('hidden', visibleRows.length > 0);
      }

      updateSortIndicators();
    };

    sortButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const nextKey = button.dataset.sort;
        if (!nextKey) {
          return;
        }
        if (sortState.key === nextKey) {
          sortState.direction = sortState.direction === 'asc' ? 'desc' : 'asc';
        } else {
          sortState.key = nextKey;
          sortState.direction = 'asc';
        }
        applyFilters();
      });
    });

    searchInput.addEventListener('input', applyFilters);
    applyFilters();
  }
</script>
